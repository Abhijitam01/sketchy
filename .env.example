# Database (PostgreSQL). For Supabase use ?sslmode=require (often required).
# If signup/signin return 503 "Cannot reach the database", resume the project in Supabase or fix the URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# JWT Secret for authentication
JWT_SECRET="replace-with-a-long-random-secret"

# Environment
NODE_ENV="development"
