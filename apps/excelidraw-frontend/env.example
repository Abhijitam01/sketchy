# Prefer defining these in the repo root `.env` (loaded by next.config.ts). This file is reference only.

# --- Local development ---
NEXT_PUBLIC_HTTP_URL=http://127.0.0.1:3000/api/backend
NEXT_PUBLIC_WS_URL=ws://localhost:8080
NEXT_PUBLIC_ENABLE_LIVE_DEMO=false

# --- Production (sketchy.abhijitamdubey.site) ---
# NEXT_PUBLIC_HTTP_URL=https://sketchy.abhijitamdubey.site/api/backend
# NEXT_PUBLIC_WS_URL=wss://<your-ws-backend-url>
# NEXT_PUBLIC_ENABLE_LIVE_DEMO=false
